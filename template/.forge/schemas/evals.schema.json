{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge/schemas/evals.schema.json",
  "title": "evals.json — casos de teste de um eval A/B de skill (§17.8.4)",
  "type": "object",
  "additionalProperties": false,
  "required": ["skill", "test_cases"],
  "properties": {
    "skill": { "type": "string", "maxLength": 64 },
    "description": { "type": "string", "maxLength": 1024 },
    "runner": { "type": "string" },
    "test_cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "prompt", "expectations"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "prompt": { "type": "string", "minLength": 1 },
          "split": { "type": "string", "enum": ["train", "test"] },
          "expectations": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
